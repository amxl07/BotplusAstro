---
interface Props {
  id?: string;
  eyebrow?: string;
  title: string;
  intro?: string;
  body?: string;
  image?: string;
  imageAlt?: string;
  video?: {
    id?: string;
    poster?: string;
    webm?: string;
    mp4?: string;
    autoplay?: boolean;
  };
  cta?: {
    label: string;
    href?: string;
    calendly?: boolean;
  };
  variant?: string;
}

const { id = 'hero', eyebrow, title, intro, body, image = '/assets/img/logo tran.svg', imageAlt = '', video, cta, variant = '' } = Astro.props;
const hasMedia = Boolean(video);
---
<section id={id} class={`hero section ${variant}`}>
  {image && <img src={image} alt={imageAlt} loading="eager" fetchpriority="high" data-aos="fade-in" />}
  <div class="container">
    <div class={`row align-items-center g-4 ${hasMedia ? '' : 'justify-content-center'}`} data-aos="fade-up">
      <div class={hasMedia ? 'col-xl-6 col-lg-7 text-left' : 'col-lg-9 text-center'}>
        {eyebrow && <p class="section-subtitle">{eyebrow}</p>}
        <h1>{title}</h1>
        {intro && <p class="solutions-italic-text"><i>{intro}</i></p>}
        {body && <p>{body}</p>}
        {cta && (
          <div class={hasMedia ? 'text-center' : 'text-center mt-4'}>
            <a href={cta.href || 'javascript:void(0);'} class="btn-common" data-calendly={cta.calendly ? 'demo' : undefined}>{cta.label}</a>
          </div>
        )}
      </div>

      {video && (
        <div class="col-xl-6 col-lg-5 video-column">
          <div class="ratio ratio-16x9">
            <video id={video.id || 'heroVideo'} autoplay={video.autoplay ?? true} muted loop playsinline class="hero-video" preload="auto" poster={video.poster}>
              {video.webm && <source src={video.webm} type="video/webm" />}
              {video.mp4 && <source src={video.mp4} type="video/mp4" />}
              Your browser does not support the video tag.
            </video>
          </div>
          <div class="video-controls text-center">
            <button id="unmuteBtn" class="btn-common btn-common--spaced" aria-label="Unmute video">
              <span class="btn-text">Unmute to hear your agent speak</span>
            </button>
          </div>
        </div>
      )}
    </div>
  </div>
</section>
