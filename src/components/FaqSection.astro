---
interface Faq {
  question: string;
  answer: string;
}

interface Props {
  id?: string;
  title?: string;
  intro?: string;
  faqs: Faq[];
  schema?: boolean;
}

const { id = 'faq', title = 'Frequently Asked Questions', intro, faqs, schema = false } = Astro.props;
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer
    }
  }))
};
---
<section id={id} class="faq section light-background">
  <div class="container section-title" data-aos="fade-up">
    <h2>{title}</h2>
    {intro && <p>{intro}</p>}
  </div>
  <div class="container faq-list">
    {faqs.map((faq) => (
      <details class="faq-item">
        <summary>{faq.question}</summary>
        <p>{faq.answer}</p>
      </details>
    ))}
  </div>
  {schema && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}
</section>
