<div class="contact-form-card">
  <div class="section-title text-start">
    <h2>Send Us a Message</h2>
    <p>Complete the form below and our team will get back to you within 24 hours.</p>
  </div>

  <form id="contactForm" class="email-form" novalidate>
    <div class="row mt-3">
      <div class="col-md-6 form-group">
        <label for="name" class="form-label">Your Name</label>
        <input type="text" name="name" class="form-control" id="name" placeholder="John Smith" required />
      </div>
      <div class="col-md-6 form-group mt-3 mt-md-0">
        <label for="email" class="form-label">Your Email</label>
        <input type="email" class="form-control" name="email" id="email" placeholder="john@company.com" required />
      </div>
    </div>
    <div class="row mt-3">
      <div class="col-md-6 form-group">
        <label for="phone" class="form-label">Phone Number</label>
        <input type="tel" name="phone" class="form-control" id="phone" placeholder="+971 50 123 4567" />
      </div>
      <div class="col-md-6 form-group mt-3 mt-md-0">
        <label for="company" class="form-label">Company</label>
        <input type="text" class="form-control" name="company" id="company" placeholder="Your Company Name" required />
      </div>
    </div>
    <div class="form-group mt-3">
      <label for="subject" class="form-label">Subject</label>
      <input type="text" class="form-control" name="subject" id="subject" placeholder="How can we help?" required />
    </div>
    <div class="form-group mt-3">
      <label for="message" class="form-label">Message</label>
      <textarea class="form-control" name="message" id="message" rows="5" placeholder="Tell us about your project or inquiry..." required></textarea>
    </div>
    <div class="text-center mt-4">
      <button type="submit" class="btn-common btn-wide">Send Message</button>
    </div>
    <div class="my-3">
      <div class="loading" style="display: none;">Sending your message...</div>
      <div class="error-message" style="display: none;">Error sending message. Please try again.</div>
      <div class="sent-message" style="display: none;">Your message has been sent. Thank you!</div>
    </div>
  </form>
</div>

<script is:inline>
  const SUPABASE_URL = 'https://ssxnamsctmryhwfdytya.supabase.co';
  const SUPABASE_ANON_KEY = 'sb_publishable_2sZvj7GxFUCRUUpi-i0RZg_8AjJzXg-';
  const BLOCKED_EMAIL_DOMAINS = ['gmail.com', 'yahoo.com', 'outlook.com', 'hotmail.com', 'icloud.com'];

  function setFormStatus(status, message) {
    const loading = document.querySelector('.loading');
    const errorMessage = document.querySelector('.error-message');
    const sentMessage = document.querySelector('.sent-message');
    if (loading) loading.style.display = status === 'loading' ? 'block' : 'none';
    if (errorMessage) {
      errorMessage.style.display = status === 'error' ? 'block' : 'none';
      if (message) errorMessage.textContent = message;
    }
    if (sentMessage) {
      sentMessage.style.display = status === 'success' ? 'block' : 'none';
      if (message) sentMessage.textContent = message;
    }
  }

  function isValidEmail(email) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  }

  function isObviousGibberish(value) {
    const text = String(value || '').trim();
    if (/\s/.test(text) || text.length <= 12 || !/^[a-z]+$/i.test(text)) return false;
    const hasUpper = /[A-Z]/.test(text);
    const hasLower = /[a-z]/.test(text);
    const vowelCount = (text.match(/[aeiou]/gi) || []).length;
    const vowelRatio = vowelCount / text.length;
    const caseSwitches = (text.match(/[a-z][A-Z]|[A-Z][a-z]/g) || []).length;
    return hasUpper && hasLower && caseSwitches >= 3 && (vowelRatio < 0.25 || vowelRatio > 0.75);
  }

  function validateLeadData(leadData) {
    const requiredFields = ['name', 'company', 'email', 'subject', 'message'];
    const missingField = requiredFields.find((field) => !leadData[field]);
    if (missingField) return `Please provide ${missingField}.`;
    if (!isValidEmail(leadData.email)) return 'Please enter a valid business email address.';
    const emailDomain = leadData.email.split('@')[1].toLowerCase();
    if (BLOCKED_EMAIL_DOMAINS.includes(emailDomain)) return 'Please use your business email address.';
    if (leadData.phone_number && /[a-z]/i.test(leadData.phone_number)) return 'Phone number cannot contain letters.';
    if (leadData.subject.length < 4) return 'Subject must be at least 4 characters.';
    if (leadData.message.length < 15) return 'Message must be at least 15 characters.';
    const textFields = ['name', 'company', 'subject', 'message'];
    const gibberishField = textFields.find((field) => isObviousGibberish(leadData[field]));
    if (gibberishField) return `Please enter a valid ${gibberishField}.`;
    return null;
  }

  async function submitLead(leadData) {
    const response = await fetch(`${SUPABASE_URL}/functions/v1/botplus-contact-submit`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'apikey': SUPABASE_ANON_KEY,
        'Authorization': `Bearer ${SUPABASE_ANON_KEY}`
      },
      body: JSON.stringify(leadData)
    });
    const data = await response.json().catch(() => ({}));
    if (!response.ok) throw new Error(data.error || 'Error sending message. Please try again.');
    return data;
  }

  function showFieldError(fieldId, message) {
    const field = document.getElementById(fieldId);
    if (!field) return;
    field.classList.add('field-invalid');
    field.classList.remove('field-valid');
    field.setAttribute('aria-invalid', 'true');
    const parent = field.closest('.form-group');
    if (!parent) return;
    let errorContainer = parent.querySelector('.field-error');
    if (!errorContainer) {
      errorContainer = document.createElement('div');
      errorContainer.className = 'field-error';
      parent.appendChild(errorContainer);
    }
    errorContainer.innerHTML = `<i class="bi bi-exclamation-circle-fill" aria-hidden="true"></i><span>${message}</span>`;
  }

  function clearFieldError(fieldId) {
    const field = document.getElementById(fieldId);
    if (!field) return;
    field.classList.remove('field-invalid');
    field.removeAttribute('aria-invalid');
    const parent = field.closest('.form-group');
    const errorContainer = parent ? parent.querySelector('.field-error') : null;
    if (errorContainer) errorContainer.remove();
  }

  function clearAllFieldErrors() {
    ['name', 'email', 'phone', 'company', 'subject', 'message'].forEach((fieldId) => {
      clearFieldError(fieldId);
      const field = document.getElementById(fieldId);
      if (field) field.classList.remove('field-valid');
    });
  }

  function getNativeFieldError(field) {
    const fieldLabels = { name: 'your name', email: 'email', company: 'your company', subject: 'a subject', message: 'your message' };
    if (field.validity.valueMissing) return `Please enter ${fieldLabels[field.id] || 'this field'}`;
    if (field.id === 'email' && field.validity.typeMismatch) return 'Please enter a valid business email address.';
    return field.validationMessage;
  }

  function getValidationErrorField(message) {
    const normalizedMessage = String(message || '').toLowerCase();
    if (normalizedMessage.includes('email') || normalizedMessage.includes('business email')) return 'email';
    if (normalizedMessage.includes('phone')) return 'phone';
    if (normalizedMessage.includes('subject')) return 'subject';
    if (normalizedMessage.includes('message')) return 'message';
    if (normalizedMessage.includes('company')) return 'company';
    if (normalizedMessage.includes('name')) return 'name';
    return null;
  }

  document.addEventListener('DOMContentLoaded', () => {
    const contactForm = document.getElementById('contactForm');
    if (!contactForm) return;

    contactForm.querySelectorAll('input, textarea').forEach((field) => {
      field.addEventListener('invalid', function(e) {
        e.preventDefault();
        showFieldError(this.id, getNativeFieldError(this));
      });
      field.addEventListener('input', function() {
        clearFieldError(this.id);
        this.classList.remove('field-valid');
      });
      field.addEventListener('blur', function() {
        if (!this.checkValidity()) showFieldError(this.id, getNativeFieldError(this));
        else if (this.value.trim()) this.classList.add('field-valid');
      });
    });

    contactForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      clearAllFieldErrors();
      setFormStatus('idle');
      if (!this.checkValidity()) {
        const firstInvalid = this.querySelector(':invalid');
        this.querySelectorAll('input, textarea').forEach((field) => {
          if (!field.checkValidity()) showFieldError(field.id, getNativeFieldError(field));
        });
        if (firstInvalid) firstInvalid.focus();
        return;
      }
      const leadData = {
        name: document.getElementById('name').value.trim(),
        company: document.getElementById('company').value.trim(),
        email: document.getElementById('email').value.trim().toLowerCase(),
        country_code: '+971',
        phone_number: document.getElementById('phone').value.trim() || null,
        subject: document.getElementById('subject').value.trim(),
        message: document.getElementById('message').value.trim(),
        source: 'site-contact',
        product: 'botplus',
        created_at: new Date().toISOString()
      };
      const validationError = validateLeadData(leadData);
      if (validationError) {
        const fieldId = getValidationErrorField(validationError);
        if (fieldId) showFieldError(fieldId, validationError);
        else setFormStatus('error', validationError);
        return;
      }
      setFormStatus('loading');
      try {
        const data = await submitLead(leadData);
        setFormStatus('success', data && data.duplicate ? "You've already submitted this form. We'll be in touch soon!" : 'Your message has been sent. Thank you!');
        this.reset();
      } catch (error) {
        console.error('Contact form submission error:', error);
        setFormStatus('error', error.message || 'Error sending message. Please try again.');
      }
    });
  });
</script>
